# ============================================================
# DISASTERMIND GROUP B — ENVIRONMENT VARIABLES
# Copy this file to .env for local development.
# NEVER commit .env — it is gitignored.
# ============================================================

# --- Group A Backend (local dev) ---
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000/ws

# --- Group A Backend (production --- set these in Vercel dashboard) ---
# VITE_API_URL=https://your-group-a-backend.railway.app
# VITE_WS_URL=wss://your-group-a-backend.railway.app/ws

# --- Ollama (local dev only --- not used in production) ---
VITE_OLLAMA_URL=http://localhost:11434
VITE_OLLAMA_MODEL=llama3.2

# --- LLM API keys (production --- set these in Vercel dashboard, NOT here) ---
# VITE_ANTHROPIC_API_KEY=sk-ant-...
# VITE_GEMINI_API_KEY=AIza...

# --- Maps (Phase 1 --- leave blank until Mapbox is integrated) ---
# VITE_MAPBOX_TOKEN=pk.eyJ1...

# --- Environment ---
VITE_ENV=development
# In Vercel dashboard set: VITE_ENV=production
