# DisasterMind configuration — copy to .env and adjust.
# Every var is read in disastermind/core/config.py (Settings). All have safe
# defaults; the system runs fully offline with none of these set.

# --- coordination loop -------------------------------------------------------
DM_LOOP_INTERVAL=30            # seconds between coordination cycles (Step 10)
DM_ESCALATION_TIMEOUT=300      # commander escalation auto-execute timeout (Step 7)
DM_GRID_METERS=100            # risk-grid cell size in metres (Step 3)

# --- message bus (Step 10: primary + backup for failover) --------------------
DM_USE_KAFKA=false            # false -> in-memory bus (default, no broker needed)
DM_KAFKA_BROKERS=localhost:9092
DM_KAFKA_BACKUP=localhost:9094

# --- storage (Step 9) --------------------------------------------------------
DM_POSTGRES_DSN=postgresql://disastermind:disastermind@localhost:5432/disastermind   # PostGIS spatial state
DM_TIMESCALE_DSN=postgresql://disastermind:disastermind@localhost:5433/dm_telemetry   # sensor time-series
DM_ELASTICSEARCH_URL=http://localhost:9200                                            # audit trail (blank -> JSONL only)
DM_AUDIT_LOG=./audit.jsonl                                                            # local hash-chained audit log

# --- external feeds (Step 2) -------------------------------------------------
DM_IMD_URL=https://mausam.imd.gov.in
DM_USGS_URL=https://earthquake.usgs.gov/earthquakes/feed/v1.0/summary/all_hour.geojson
DM_FIRMS_KEY=                  # NASA FIRMS API key (blank -> offline samples)
DM_OPENMETEO_URL=https://api.open-meteo.com/v1/forecast

# --- dispatch credentials (Step 8; blank -> dry-run, records would-be sends) -
DM_TWILIO_SID=
DM_TWILIO_TOKEN=
DM_FCM_KEY=
DM_IRIDIUM_URL=

# --- LLM escalation layer (Group B; blank -> deterministic template, no network) ---
DM_ANTHROPIC_KEY=             # or ANTHROPIC_API_KEY; uses claude-opus-4-8 when set

# --- dashboard API / security (api + security packages) ----------------------
DM_API_HOST=127.0.0.1
DM_API_PORT=8000
DM_API_KEYS=                  # comma-separated bearer tokens; blank -> auth OFF (open)
DM_API_KEYS_MAP=              # optional principal:token pairs (e.g. "ndma:tok1,sdrf:tok2")
DM_RATE_CAPACITY=60           # rate-limiter token-bucket capacity per principal
DM_RATE_REFILL_PER_SEC=10     # rate-limiter refill rate

# --- ML models (prediction seam uses trained artifacts when present) ----------
DM_MODELS_DIR=                # dir of trained model_{A,B,C}.json; blank -> heuristics

# --- live mode switches (all default OFF -> fully offline/deterministic) -------
DM_LIVE=false                 # LiveSystem: wire real backends (storage/Kafka) when DSNs set
DM_FEEDS_LIVE=false           # poll real feed endpoints (USGS/Open-Meteo) instead of samples
DM_SOCIAL_LIVE=false          # social-NLP live ingestion
DM_DISPATCH_LIVE=false        # dispatch via real channels instead of dry-run
DM_FIELDAPP_TEAMS=            # comma-separated team ids for demo MockFieldClients
